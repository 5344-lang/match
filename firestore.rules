rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAuth() && (request.auth.uid == uid || isAdmin());
    }

    match /requests/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if isAuth() && (request.auth.uid == uid || isAdmin());
    }

    match /settings/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /bannedUsers/{uid} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
